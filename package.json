{
  "name": "@fyio/payfyio",
  "version": "0.5.0",
  "description": "Unified payment gateway library for payment providers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "canary": "tsup examples/iyzico-example.ts --format cjs,esm --dts",
    "test": "vitest",
    "test:unit": "vitest tests/unit",
    "test:integration": "vitest tests/integration",
    "test:e2e": "vitest tests/e2e",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "keywords": [
    "payment",
    "gateway",
    "iyzico",
    "paytr",
    "akbank",
    "parampos",
    "stripe",
    "paypal",
    "garanti",
    "isbank",
    "yapikredi",
    "ziraat",
    "turkey",
    "turkish",
    "payment-gateway",
    "typescript",
    "payment-provider",
    "provider",
    "e-commerce",
    "online-payment",
    "3d-secure",
    "nodejs",
    "nextjs"
  ],
  "author": "tsmart-team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsmart-team/payfyio.git"
  },
  "bugs": {
    "url": "https://github.com/tsmart-team/payfyio/issues"
  },
  "homepage": "https://github.com/tsmart-team/payfyio#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "axios": "^1.16.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
